# ─────────────────────────────────────────────────────────────────────────────
#  FINTECH — Variables de entorno para Docker Compose
#  (No subir este archivo a repositorios públicos)
# ─────────────────────────────────────────────────────────────────────────────

# ── Base de datos PostgreSQL ─────────────────────────────────────────────────
DB_USERNAME=fintech_user
DB_PASSWORD=fintech_password123
DB_DATABASE=fintech_db

# ── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=super_secreto_jwt_fintech_2026_cambia_esto_en_produccion
JWT_REFRESH_SECRET=super_secreto_refresh_fintech_2026_cambia_esto_en_produccion
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── Servidor ─────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=production
CORS_ORIGIN=http://localhost:3000
CORS_CREDENTIALS=true

# ── Archivos ─────────────────────────────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760
